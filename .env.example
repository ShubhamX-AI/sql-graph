MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=user
MYSQL_PASSWORD=mypasword
MYSQL_DATABASE=mydb

MYSQL_SEED_HOST=localhost
MYSQL_SEED_PORT=3306
MYSQL_SEED_USER=
MYSQL_SEED_PASSWORD=
MYSQL_SEED_DATABASE=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMS=1536
ENABLE_FUZZY_VALUE_RESOLUTION=true
FUZZY_MATCH_MIN_SCORE=90
FUZZY_MATCH_MIN_LEAD=5
FUZZY_MATCH_MAX_CANDIDATES=2000
FUZZY_MATCH_CACHE_TTL_SECONDS=300
FUZZY_MATCH_MIN_VALUE_LENGTH=3

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
